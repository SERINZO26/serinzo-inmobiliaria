TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=              # Formato: whatsapp:+57XXXXXXXXXX

# ─── EMAIL ────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@inmobiliaria.com
CONTACT_EMAIL_TO=info@serinzo.com    # Destino del formulario de contacto del sitio web

# ─── GOOGLE CALENDAR ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
